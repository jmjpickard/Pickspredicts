---
import Layout from "../../layouts/Layout.astro";
import RunnerTable from "../../components/RunnerTable.astro";
import {
  getRaceDays,
  getTopPick,
  raceHasResults,
  toBoolean,
  toNumber,
  topPickWinPl,
  topPickWon,
  type Race,
} from "../../types";

import predictions from "../../../public/predictions.json";

const races = predictions as Race[];

export function getStaticPaths() {
  const allRaces = predictions as Race[];
  return allRaces.map((race) => ({
    params: { id: race.race_id },
  }));
}

const { id } = Astro.params;
const race = races.find((r) => r.race_id === id);

if (!race) {
  return Astro.redirect("/");
}

const days = getRaceDays(races);
const raceDate = (race.date ?? "").slice(0, 10);
const isFirstDay = days[0]?.date === raceDate;
const backLabel = days.find((day) => day.date === raceDate)?.label ?? "All races";
const backHref = !raceDate || isFirstDay ? "/" : `/day/${raceDate}`;

const time = race.off_time ?? "";
const name = race.race_name ?? `Race ${race.race_id}`;
const course = race.course ?? "";
const type = race.race_type ?? "";
const cls = race.race_class ? `${race.race_class}` : "";
const distance = toNumber(race.distance_f);
const dist = distance !== null ? `${distance}f` : "";
const badges = [course, type, cls, dist].filter(Boolean);
const handicapBadge = toBoolean(race.is_handicap);
const patternBadge = race.pattern && race.pattern !== "None" && race.pattern !== "";

const showResults = raceHasResults(race);
const topPick = getTopPick(race);
const topPickPl = topPickWinPl(race);
const topPickIsWinner = topPickWon(race);
const bets = race.runners.filter((r) => toBoolean(r.is_bet));
const winPl = toNumber(race.race_win_pl) ?? 0;
const ewPl = toNumber(race.race_ew_pl) ?? 0;

function plStr(v: number): string {
  return `${v >= 0 ? "+" : ""}${v.toFixed(2)}`;
}

function plColor(v: number): string {
  if (v > 0) return "text-emerald-700";
  if (v < 0) return "text-red-600";
  return "text-gray-600";
}
---

<Layout title={`${name} — Aintree Festival Tracker`}>
  <a href={backHref} class="mb-4 inline-flex items-center text-sm text-gray-500 hover:text-racing-green">
    &larr; {backLabel}
  </a>

  <div class="mb-6">
    <div class="flex items-center gap-2 mb-1">
      {time && (
        <span class="text-lg font-semibold text-racing-green">{time}</span>
      )}
      <h2 class="text-xl font-bold">{name}</h2>
    </div>
    <div class="flex flex-wrap gap-1.5 mt-2">
      {badges.map((b) => (
        <span class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
          {b}
        </span>
      ))}
      {handicapBadge && (
        <span class="inline-block rounded bg-amber-50 px-2 py-0.5 text-xs text-amber-700 border border-amber-200">
          Handicap
        </span>
      )}
      {patternBadge && (
        <span class="inline-block rounded bg-purple-50 px-2 py-0.5 text-xs text-purple-700 border border-purple-200">
          {race.pattern}
        </span>
      )}
      <span class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
        {race.runners.length} runners
      </span>
      {toNumber(race.num_places_paid) && (
        <span class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
          {race.num_places_paid} places @ {race.place_fraction}
        </span>
      )}
    </div>
  </div>

  {(topPick || bets.length > 0) && (
    <div class="mb-4 grid gap-3 md:grid-cols-2">
      {topPick && (
        <div class="rounded-lg border border-racing-green/20 bg-white p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-racing-green">Top-Pick Benchmark</p>
          <div class="mt-2 flex items-start justify-between gap-4">
            <div>
              <p class="text-lg font-semibold text-gray-900">{topPick.horse_name}</p>
              <p class="mt-1 text-sm text-gray-500">
                Model win chance {`${(topPick.win_prob * 100).toFixed(1)}%`}
              </p>
            </div>
            <div class="text-right">
              <span class="text-xs text-gray-500 uppercase">1pt Win</span>
              <p class={`text-base font-bold tabular-nums ${plColor(topPickPl ?? 0)}`}>
                {topPickPl === null ? "Pending" : plStr(topPickPl)}
              </p>
            </div>
          </div>
          {topPickPl !== null && (
            <p class={`mt-3 text-sm font-medium ${topPickIsWinner ? "text-emerald-700" : "text-red-600"}`}>
              {topPickIsWinner ? "Top pick won." : "Top pick lost."}
            </p>
          )}
        </div>
      )}

      {bets.length > 0 && (
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-gray-500">Strong-Value Overlay</p>
          <div class="mt-2 flex items-center justify-between">
            <p class="text-sm text-gray-600">
              <span class="font-semibold">{bets.length}</span> bet{bets.length > 1 ? "s" : ""} in this race
            </p>
            <div class="flex gap-5">
              <div class="text-right">
                <span class="text-xs text-gray-500 uppercase">Win</span>
                <p class={`text-base font-bold tabular-nums ${plColor(winPl)}`}>
                  {plStr(winPl)}
                </p>
              </div>
              <div class="text-right">
                <span class="text-xs text-gray-500 uppercase">E/W</span>
                <p class={`text-base font-bold tabular-nums ${plColor(ewPl)}`}>
                  {plStr(ewPl)}
                </p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  )}

  <div class="bg-white rounded-lg border border-gray-200 p-4">
    <RunnerTable runners={race.runners} showResults={showResults} />
  </div>
</Layout>
