---
import DayTabs from "./DayTabs.astro";
import FestivalTracker from "./FestivalTracker.astro";
import RaceCard from "./RaceCard.astro";
import ReturnsBanner from "./ReturnsBanner.astro";
import { getRaceDays, raceHasResults, toNumber, type Race } from "../types";

interface Props {
  activeDate?: string;
  races: Race[];
}

const { activeDate, races } = Astro.props;

const days = getRaceDays(races);
const selectedDate = days.some((d) => d.date === activeDate) ? activeDate : days[0]?.date;
const selectedLabel = days.find((d) => d.date === selectedDate)?.label ?? selectedDate ?? "";

const hasResults = races.some((race) => raceHasResults(race));

const dayRaces = races
  .filter((r) => selectedDate && r.date?.startsWith(selectedDate))
  .sort((a, b) => (a.off_time ?? "").localeCompare(b.off_time ?? ""));

const dayPlanA = dayRaces
  .filter((race) => (toNumber(race.plan_a_points) ?? 0) > 0 && !!race.plan_a_pick_horse_name)
  .map((race) => ({
    raceId: race.race_id,
    offTime: race.off_time ?? "",
    raceName: race.race_name ?? `Race ${race.race_id}`,
    horseName: race.plan_a_pick_horse_name ?? "",
    points: toNumber(race.plan_a_points) ?? 0,
  }))
  .sort((a, b) => a.offTime.localeCompare(b.offTime) || (b.points - a.points));

const dayPlanATotal = dayPlanA.reduce((sum, pick) => sum + pick.points, 0);
const settledDayRaces = dayRaces.filter((race) => raceHasResults(race));

const racesExist = races.length > 0;
const dayHasRaces = dayRaces.length > 0;
---

{!racesExist ? (
  <div class="text-center py-16">
    <h2 class="mb-2 text-xl font-semibold text-gray-700">No predictions yet</h2>
    <p class="text-gray-500">
      Predictions will appear once the meeting racecards are declared.
    </p>
  </div>
) : (
  <>
    <FestivalTracker activeDate={selectedDate} races={races} />

    <DayTabs activeDate={selectedDate ?? ""} days={days} />

    {dayPlanA.length > 0 && (
      <section class="mb-6 rounded-[24px] border border-racing-green/20 bg-white px-5 py-4 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-racing-green">
              {selectedLabel} Plan A
            </h2>
            <p class="mt-1 text-sm text-gray-500">Primary staking book for the selected day.</p>
          </div>
          <p class="text-lg font-semibold tabular-nums text-racing-green">{dayPlanATotal.toFixed(1)}pt</p>
        </div>
        <ul class="mt-4 grid gap-2 sm:grid-cols-2">
          {dayPlanA.map((pick) => (
            <li class="rounded-2xl bg-racing-cream px-3 py-2 text-sm text-gray-700">
              <span class="font-semibold text-racing-green">{pick.points.toFixed(1)}pt</span>
              {" "}
              <span class="font-medium text-gray-900">{pick.horseName}</span>
              <span class="text-gray-500"> at {pick.offTime}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {hasResults && settledDayRaces.length > 0 && (
      <ReturnsBanner allRaces={races} races={dayRaces} label={`${selectedLabel} Returns`} />
    )}

    {!dayHasRaces ? (
      <div class="text-center py-12">
        <p class="text-gray-500">
          No races for {selectedLabel} yet.
        </p>
      </div>
    ) : (
      <div class="space-y-3">
        {dayRaces.map((race) => (
          <RaceCard race={race} showResults={raceHasResults(race)} />
        ))}
      </div>
    )}
  </>
)}
