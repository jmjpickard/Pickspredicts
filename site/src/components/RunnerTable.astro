---
import { toBoolean, toNumber, type Runner } from "../types";

interface Props {
  runners: Runner[];
  showResults?: boolean;
}

const { runners, showResults = false } = Astro.props;

const sorted = [...runners].sort((a, b) => {
  const aValue = toNumber(a.value_score);
  const bValue = toNumber(b.value_score);
  if (aValue === null && bValue === null) return b.win_prob - a.win_prob;
  if (aValue === null) return 1;
  if (bValue === null) return -1;
  return bValue - aValue;
});

function pct(v: number | string | null | undefined): string {
  const numeric = toNumber(v);
  if (numeric === null) return "—";
  return `${(numeric * 100).toFixed(1)}%`;
}

function oddsStr(v: number | string | null | undefined): string {
  const numeric = toNumber(v);
  if (numeric === null) return "—";
  return numeric.toFixed(1);
}

function valueClass(v: number | string | null): string {
  const numeric = toNumber(v);
  if (numeric === null) return "text-gray-400";
  if (numeric >= 0.05) return "text-emerald-700 font-semibold";
  if (numeric >= -0.03) return "text-gray-700";
  return "text-red-600";
}

function verdictClass(verdict: string): string {
  if (verdict === "Strong value") return "bg-emerald-50 text-emerald-700 border-emerald-200";
  if (verdict === "Fair price") return "bg-gray-50 text-gray-600 border-gray-200";
  if (verdict === "No odds") return "bg-slate-50 text-slate-600 border-slate-200";
  return "bg-red-50 text-red-600 border-red-200";
}

function rowClass(runner: Runner): string {
  if (!showResults && (toNumber(runner.plan_a_points) ?? 0) > 0) {
    return "bg-racing-green/5 hover:bg-racing-green/10";
  }
  if (!showResults) return "hover:bg-gray-50";
  if (toBoolean(runner.won)) return "bg-emerald-50/60 hover:bg-emerald-50";
  if (toBoolean(runner.placed)) return "bg-amber-50/50 hover:bg-amber-50";
  return "hover:bg-gray-50";
}

function posStr(pos: number | string | null | undefined): string {
  const numeric = toNumber(pos);
  if (numeric === null) return "—";
  if (numeric === 1) return "1st";
  if (numeric === 2) return "2nd";
  if (numeric === 3) return "3rd";
  return `${numeric}th`;
}

function posClass(pos: number | string | null | undefined): string {
  const numeric = toNumber(pos);
  if (numeric === 1) return "text-emerald-700 font-bold";
  if (numeric !== null && numeric <= 3) return "text-amber-700 font-semibold";
  return "text-gray-500";
}

function plStr(v: number | string | null | undefined): string {
  const numeric = toNumber(v);
  if (numeric === null) return "";
  return `${numeric >= 0 ? "+" : ""}${numeric.toFixed(2)}`;
}

function plClass(v: number | string | null | undefined): string {
  const numeric = toNumber(v);
  if (numeric === null) return "";
  if (numeric > 0) return "text-emerald-700 font-semibold";
  if (numeric < 0) return "text-red-500";
  return "text-gray-500";
}

function planAPointsLabel(points: number | string | null | undefined): string {
  const numeric = toNumber(points);
  return numeric === null ? "" : numeric.toFixed(1);
}

function valueLabel(v: number | string | null): string {
  const numeric = toNumber(v);
  if (numeric === null) return "—";
  return `${numeric >= 0 ? "+" : ""}${(numeric * 100).toFixed(1)}%`;
}
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
        {showResults && <th class="py-3 pr-2 text-center w-12">Pos</th>}
        <th class="py-3 pr-3">Horse</th>
        <th class="py-3 px-2 text-right">OR</th>
        <th class="py-3 px-2 text-right">Win%</th>
        <th class="py-3 px-2 text-right">Place%</th>
        <th class="py-3 px-2 text-right">SP</th>
        <th class="py-3 px-2 text-right">Implied</th>
        <th class="py-3 px-2 text-right">Value</th>
        <th class="py-3 pl-2">Verdict</th>
        {showResults && <th class="py-3 px-2 text-right">Win P&L</th>}
        {showResults && <th class="py-3 px-2 text-right">E/W P&L</th>}
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {sorted.map((runner) => (
        <tr class={rowClass(runner)}>
          {showResults && (
            <td class={`py-3 pr-2 text-center tabular-nums ${posClass(runner.finish_position)}`}>
              {posStr(runner.finish_position)}
            </td>
          )}
          <td class="py-3 pr-3">
            <div class="flex items-center gap-1.5">
              {showResults && toBoolean(runner.won) && (
                <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 shrink-0" />
              )}
              {showResults && toBoolean(runner.placed) && !toBoolean(runner.won) && (
                <span class="inline-block w-2 h-2 rounded-full bg-amber-400 shrink-0" />
              )}
              <span class="font-medium text-gray-900">{runner.horse_name}</span>
              {toBoolean(runner.is_bet) && (
                <span class="inline-block rounded bg-emerald-100 px-1 py-0.5 text-[10px] font-bold text-emerald-700 uppercase leading-none">
                  Bet
                </span>
              )}
              {(toNumber(runner.plan_a_points) ?? 0) > 0 && (
                <span class="inline-block rounded bg-racing-green/15 px-1.5 py-0.5 text-[10px] font-bold text-racing-green uppercase leading-none">
                  Plan A {planAPointsLabel(runner.plan_a_points)}pt
                </span>
              )}
            </div>
            <details class="mt-1">
              <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600">
                Top factors
              </summary>
              <p class="text-xs text-gray-500 mt-1 leading-relaxed">
                {runner.top_features}
              </p>
            </details>
          </td>
          <td class="py-3 px-2 text-right text-gray-600 tabular-nums">
            {toNumber(runner.official_rating) ?? "—"}
          </td>
          <td class="py-3 px-2 text-right tabular-nums font-medium">
            {pct(runner.win_prob)}
          </td>
          <td class="py-3 px-2 text-right tabular-nums text-gray-600">
            {pct(runner.place_prob)}
          </td>
          <td class="py-3 px-2 text-right tabular-nums text-gray-600">
            {oddsStr(runner.sp_decimal ?? runner.best_odds)}
          </td>
          <td class="py-3 px-2 text-right tabular-nums text-gray-600">
            {pct(runner.implied_prob)}
          </td>
          <td class={`py-3 px-2 text-right tabular-nums ${valueClass(runner.value_score)}`}>
            {valueLabel(runner.value_score)}
          </td>
          <td class="py-3 pl-2">
            <span
              class={`inline-block rounded border px-2 py-0.5 text-xs font-medium ${verdictClass(runner.verdict)}`}
            >
              {runner.verdict}
            </span>
          </td>
          {showResults && (
            <td class={`py-3 px-2 text-right tabular-nums text-xs ${plClass(runner.win_pl)}`}>
              {toBoolean(runner.is_bet) ? plStr(runner.win_pl) : ""}
            </td>
          )}
          {showResults && (
            <td class={`py-3 px-2 text-right tabular-nums text-xs ${plClass(runner.ew_pl)}`}>
              {toBoolean(runner.is_bet) ? plStr(runner.ew_pl) : ""}
            </td>
          )}
        </tr>
      ))}
    </tbody>
  </table>
</div>
