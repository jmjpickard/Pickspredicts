---
import { toBoolean, toNumber, type Race } from "../types";

interface Props {
  race: Race;
  showResults?: boolean;
}

const { race, showResults = false } = Astro.props;

const valueCount = race.runners.filter(
  (r) => r.value_score !== null && r.value_score >= 0.05
).length;

const time = race.off_time ?? "";
const name = race.race_name ?? `Race ${race.race_id}`;
const course = race.course ?? "";
const type = race.race_type ?? "";
const cls = race.race_class ? `${race.race_class}` : "";
const distance = toNumber(race.distance_f);
const dist = distance !== null ? `${distance}f` : "";
const badges = [course, type, cls, dist].filter(Boolean);

const handicapBadge = toBoolean(race.is_handicap);
const patternBadge = race.pattern && race.pattern !== "None" && race.pattern !== "";

// Result info
const bets = race.runners.filter((r) => toBoolean(r.is_bet));
const winners = bets.filter((r) => toBoolean(r.won));
const placed = bets.filter((r) => toBoolean(r.placed) && !toBoolean(r.won));
const winPl = toNumber(race.race_win_pl) ?? 0;
const planAPoints = toNumber(race.plan_a_points) ?? 0;
const analysis = (race.analysis ?? "").trim();
const planAPick = race.plan_a_pick_horse_name ?? "";

function plStr(v: number): string {
  return `${v >= 0 ? "+" : ""}${v.toFixed(2)}`;
}
---

<a
  href={`/race/${race.race_id}`}
  class="block rounded-[24px] border border-gray-200 bg-white p-4 transition-all hover:border-racing-green hover:shadow-sm"
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 mb-1">
        {time && (
          <span class="text-sm font-semibold text-racing-green">{time}</span>
        )}
        <h3 class="text-base font-semibold truncate">{name}</h3>
      </div>
      <div class="flex flex-wrap gap-1.5 mt-1.5">
        {badges.map((b) => (
          <span class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
            {b}
          </span>
        ))}
        {handicapBadge && (
          <span class="inline-block rounded bg-amber-50 px-2 py-0.5 text-xs text-amber-700 border border-amber-200">
            Handicap
          </span>
        )}
        {patternBadge && (
          <span class="inline-block rounded bg-purple-50 px-2 py-0.5 text-xs text-purple-700 border border-purple-200">
            {race.pattern}
          </span>
        )}
      </div>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <span class="text-xs text-gray-400">{race.runners.length} runners</span>
      {!showResults && valueCount > 0 && (
        <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200">
          {valueCount} value
        </span>
      )}
      {showResults && bets.length > 0 && (
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1">
            {winners.length > 0 && (
              <span class="inline-flex items-center gap-0.5 rounded-full bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500" />
                {winners.length}W
              </span>
            )}
            {placed.length > 0 && (
              <span class="inline-flex items-center gap-0.5 rounded-full bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-700 border border-amber-200">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-400" />
                {placed.length}P
              </span>
            )}
          </div>
          <span class={`text-xs font-semibold tabular-nums ${winPl >= 0 ? "text-emerald-700" : "text-red-500"}`}>
            {plStr(winPl)}
          </span>
        </div>
      )}
    </div>
  </div>
  {planAPick && planAPoints > 0 && (
    <p class="mt-3 text-xs font-semibold text-racing-green">
      Plan A: {planAPoints.toFixed(1)}pt on {planAPick}
    </p>
  )}
  {analysis && (
    <p class="mt-3 border-t border-gray-100 pt-3 text-sm text-gray-600 leading-relaxed">
      <span class="font-semibold text-gray-800">AI view:</span>{" "}
      {analysis}
    </p>
  )}
</a>
