EMAIL=
AUTH_STATE=
ACCESS_TOKEN=

# Anthropic (for comment parsing via Claude Haiku)
ANTHROPIC_API_KEY=

# Betfair Exchange API
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
